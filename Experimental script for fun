-- Returns { hrp, name } for nearest player OR bot
local function getNearest()
    local mc = lp.Character; if not mc then return end
    local mh = mc:FindFirstChild("HumanoidRootPart"); if not mh then return end
    local bestHRP, bestName, bd = nil, nil, math.huge

    -- Check players
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (hrp.Position - mh.Position).Magnitude
                if d < bd then bestHRP = hrp; bestName = p.DisplayName; bd = d end
            end
        end
    end

    -- Check bots (botCache is keyed by Model)
    for model in pairs(botCache) do
        if model and model.Parent then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (hrp.Position - mh.Position).Magnitude
                if d < bd then bestHRP = hrp; bestName = "[BOT] " .. model.Name; bd = d end
            end
        end
    end

    return bestHRP, bestName
end

local function doStartTL()
    if tlEnabled then doStopTL(); return end
    local hrp, name = getNearest()
    if not hrp then
        tlStatusLbl.Text = "No target found!"; return
    end
    local hum = hrp.Parent and hrp.Parent:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    tlEnabled              = true
    tlTarget               = hrp   -- store HRP directly, works for both players and bots
    tlStatusLbl.Text       = "Locked: " .. name
    tlStatusLbl.TextColor3 = Color3.fromRGB(65, 245, 95)
    tlConn = RunService.RenderStepped:Connect(function()
        if not tlTarget or not tlTarget.Parent then doStopTL(); return end
        local tu = tlTarget.Parent:FindFirstChildOfClass("Humanoid")
        if not tu or tu.Health <= 0 then doStopTL(); return end
        if cam.CameraType ~= Enum.CameraType.Scriptable then
            local head = tlTarget.Parent and tlTarget.Parent:FindFirstChild("Head")
            local aimPos = head and head.Position or tlTarget.Position
            cam.CFrame = CFrame.new(cam.CFrame.Position, aimPos)
        end
    end)
end

newButton(tlSection, "🎯  Toggle Target Lock", Color3.fromRGB(68, 48, 165), doStartTL)

-- ═══════════════════════════════════════════════════════════
-- ESP ENGINE  (Frame-based — no Drawing API required)
-- ═══════════════════════════════════════════════════════════
local espCache = {}
-- [Player] = { hl, bb, nameLbl, infoLbl, boxLines{4}, tracer, skelLines{14} }

-- World → screen coords
local function w2s(pos)
    local v, on = cam:WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), on, v.Z
end

-- Compute 2-D screen-space AABB from all character BaseParts
local function charBounds(char)
    local x0, y0 = math.huge,  math.huge
    local x1, y1 = -math.huge, -math.huge
    local hit = false
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local hs = part.Size * 0.5
            for _, c in ipairs(CORNERS) do
                local sp, on, d = w2s((part.CFrame * CFrame.new(hs * c)).Position)
                if on and d > 0 then
                    hit = true
                    if sp.X < x0 then x0 = sp.X end
                    if sp.Y < y0 then y0 = sp.Y end
                    if sp.X > x1 then x1 = sp.X end
                    if sp.Y > y1 then y1 = sp.Y end
                end
            end
        end
    end
    if hit then return x0, y0, x1, y1 end
end

-- Create a rotatable Frame that acts as a 2-D line
local function newLineFrame(color, thick)
    local f = Instance.new("Frame")
    f.AnchorPoint      = Vector2.new(0.5, 0.5)
    f.BackgroundColor3 = color or C_RED
    f.BorderSizePixel  = 0
    f.ZIndex           = 2
    f.Visible          = false
    f.Size             = UDim2.new(0, 0, 0, thick or 2)
    f.Parent           = espLayer
    return f
end

-- Update a line Frame to stretch from p1 to p2 (both Vector2)
local function drawLine(f, p1, p2, thick)
    if not f then return end
    local delta = p2 - p1
    local len   = delta.Magnitude
    if len < 1 then f.Visible = false; return end
    f.Size     = UDim2.new(0, len, 0, thick or 2)
    f.Position = UDim2.new(0, (p1.X + p2.X) * 0.5, 0, (p1.Y + p2.Y) * 0.5)
    f.Rotation = math.deg(math.atan2(delta.Y, delta.X))
    f.Visible  = true
end

-- Allocate all ESP objects for a player
local function buildESP(p)
    if espCache[p] then return end
    local d = {}

    -- Highlight instance (built-in Roblox — reliable outline + fill)
    d.hl                     = Instance.new("Highlight")
    d.hl.FillColor           = C_RED
    d.hl.OutlineColor        = C_WHITE
    d.hl.FillTransparency    = 0.6
    d.hl.OutlineTransparency = 0
    d.hl.Enabled             = false
    d.hl.Parent              = workspace

    -- BillboardGui: always-on-top name plate above HRP
    d.bb             = Instance.new("BillboardGui")
    d.bb.Size        = UDim2.new(0, 210, 0, 58)
    d.bb.StudsOffset = Vector3.new(0, 3.5, 0)
    d.bb.AlwaysOnTop = true
    d.bb.Enabled     = false
    d.bb.Parent      = workspace

    d.nameLbl = Instance.new("TextLabel")
    d.nameLbl.Size                   = UDim2.new(1, 0, 0, 16)
    d.nameLbl.BackgroundTransparency = 1
    d.nameLbl.TextColor3             = C_WHITE
    d.nameLbl.TextSize               = 12
    d.nameLbl.Font                   = Enum.Font.GothamBold
    d.nameLbl.TextStrokeTransparency = 0.45
    d.nameLbl.Parent                 = d.bb

    d.infoLbl = Instance.new("TextLabel")
    d.infoLbl.Size                   = UDim2.new(1, 0, 0, 42)
    d.infoLbl.Position               = UDim2.new(0, 0, 0, 16)
    d.infoLbl.BackgroundTransparency = 1
    d.infoLbl.TextColor3             = Color3.fromRGB(130, 255, 130)
    d.infoLbl.TextSize               = 10
    d.infoLbl.Font                   = Enum.Font.Gotham
    d.infoLbl.TextStrokeTransparency = 0.45
    d.infoLbl.TextWrapped            = true
    d.infoLbl.Parent                 = d.bb

    -- 2-D box: 4 Frame lines (top, bottom, left, right)
    d.boxLines = {}
    for _ = 1, 4 do table.insert(d.boxLines, newLineFrame(C_RED, 2)) end

    -- Tracer line
    d.tracer = newLineFrame(C_RED, 2)

    -- Skeleton lines (one per bone pair)
    d.skelLines = {}
    for _ = 1, #BONES do table.insert(d.skelLines, newLineFrame(C_YELLOW, 1.5)) end

    espCache[p] = d
end

-- Free all ESP objects for a player
local function destroyESP(p)
    local d = espCache[p]; if not d then return end
    if d.hl     then d.hl:Destroy() end
    if d.bb     then d.bb:Destroy() end
    if d.tracer then d.tracer:Destroy() end
    for _, l in ipairs(d.boxLines  or {}) do l:Destroy() end
    for _, l in ipairs(d.skelLines or {}) do l:Destroy() end
    espCache[p] = nil
end

-- Hide all visuals without destroying (called when ESP master is off)
local function hideAll(d)
    if d.hl     then d.hl.Enabled    = false end
    if d.bb     then d.bb.Enabled    = false end
    if d.tracer then d.tracer.Visible = false end
    for _, l in ipairs(d.boxLines  or {}) do l.Visible = false end
    for _, l in ipairs(d.skelLines or {}) do l.Visible = false end
end

Players.PlayerRemoving:Connect(destroyESP)

-- ═══════════════════════════════════════════════════════════
-- BOT ESP  (orange — non-player humanoid models)
-- ═══════════════════════════════════════════════════════════
local C_ORANGE = Color3.fromRGB(255, 140, 0)

local function buildBotESP(model)
    if botCache[model] then return end
    local d = {}

    d.hl                     = Instance.new("Highlight")
    d.hl.FillColor           = C_ORANGE
    d.hl.OutlineColor        = C_WHITE
    d.hl.FillTransparency    = 0.6
    d.hl.OutlineTransparency = 0
    d.hl.Enabled             = false
    d.hl.Parent              = workspace

    d.bb             = Instance.new("BillboardGui")
    d.bb.Size        = UDim2.new(0, 165, 0, 38)
    d.bb.StudsOffset = Vector3.new(0, 3.5, 0)
    d.bb.AlwaysOnTop = true
    d.bb.Enabled     = false
    d.bb.Parent      = workspace

    d.nameLbl = Instance.new("TextLabel")
    d.nameLbl.Size                   = UDim2.new(1, 0, 0.52, 0)
    d.nameLbl.BackgroundTransparency = 1
    d.nameLbl.TextColor3             = C_ORANGE
    d.nameLbl.TextSize               = 12
    d.nameLbl.Font                   = Enum.Font.GothamBold
    d.nameLbl.TextStrokeTransparency = 0.45
    d.nameLbl.Parent                 = d.bb

    d.infoLbl = Instance.new("TextLabel")
    d.infoLbl.Size                   = UDim2.new(1, 0, 0.48, 0)
    d.infoLbl.Position               = UDim2.new(0, 0, 0.52, 0)
    d.infoLbl.BackgroundTransparency = 1
    d.infoLbl.TextColor3             = Color3.fromRGB(255, 200, 100)
    d.infoLbl.TextSize               = 10
    d.infoLbl.Font                   = Enum.Font.Gotham
    d.infoLbl.TextStrokeTransparency = 0.45
    d.infoLbl.Parent                 = d.bb

    d.boxLines = {}
    for _ = 1, 4 do table.insert(d.boxLines, newLineFrame(C_ORANGE, 2)) end

    d.tracer = newLineFrame(C_ORANGE, 2)

    d.skelLines = {}
    for _ = 1, #BONES do table.insert(d.skelLines, newLineFrame(C_ORANGE, 1.5)) end

    botCache[model] = d
end

local function destroyBotESP(model)
    local d = botCache[model]; if not d then return end
    if d.hl     then d.hl:Destroy() end
    if d.bb     then d.bb:Destroy() end
    if d.tracer then d.tracer:Destroy() end
    for _, l in ipairs(d.boxLines  or {}) do l:Destroy() end
    for _, l in ipairs(d.skelLines or {}) do l:Destroy() end
    botCache[model] = nil
end

-- Collect all current player character models so we can exclude them
local function getPlayerChars()
    local chars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then chars[p.Character] = true end
    end
    return chars
end

-- Scan workspace every 1 second for non-player Humanoid models
task.spawn(function()
    while true do
        task.wait(1)
        if not (espEnabled or espAllEnabled) then continue end

        local playerChars = getPlayerChars()
        local found       = {}

        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Humanoid") then
                local model = obj.Parent
                -- Must be a Model, not a player character, not our own character
                if model and model:IsA("Model")
                   and not playerChars[model]
                   and model ~= lp.Character
                   and model:FindFirstChild("HumanoidRootPart") then
                    found[model] = true
                    if not botCache[model] then
                        buildBotESP(model)
                    end
                end
            end
        end

        -- Prune bots that no longer exist or lost their HRP
        for model in pairs(botCache) do
            if not found[model] then
                destroyBotESP(model)
            end
        end
    end
end)

-- ═══════════════════════════════════════════════════════════
-- MAIN RENDER LOOP
-- ═══════════════════════════════════════════════════════════
RunService.RenderStepped:Connect(function()
    local mc = lp.Character
    local mh = mc and mc:FindFirstChild("HumanoidRootPart")
    local mu = mc and mc:FindFirstChildOfClass("Humanoid")

    -- ── ESP ───────────────────────────────────────────────────
    local anyEsp = espEnabled or espAllEnabled
    if not anyEsp then
        for _, d in pairs(espCache) do hideAll(d) end
        for _, d in pairs(botCache) do hideAll(d) end
        return
    end

    local JAIL_TEAMS  = { prisoner = true, criminal = true, prison = true }
    local myTeam      = lp.Team
    local myTeamName  = myTeam and myTeam.Name:lower() or nil
    local iAmJailSide = myTeamName and JAIL_TEAMS[myTeamName] or false

    local function shouldESP(p)
        local theirTeam     = p.Team
        local theirTeamName = theirTeam and theirTeam.Name:lower() or nil
        if iAmJailSide and theirTeamName and JAIL_TEAMS[theirTeamName] then return false end
        if myTeam and theirTeam and myTeam == theirTeam then return false end
        return true
    end

    -- ── Player cache ──────────────────────────────────────────
    local wanted = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            -- espEnabled uses team filter; espAllEnabled bypasses it
            local include = espAllEnabled or (espEnabled and shouldESP(p))
            if include then
                wanted[p] = true
                if not espCache[p] then buildESP(p) end
            end
        end
    end
    for p in pairs(espCache) do
        if not wanted[p] then destroyESP(p) end
    end

    -- Tracer start: my HRP screen pos
    local vp = cam.ViewportSize
    local tracerStart
    if mh then
        local sp, on, d = w2s(mh.Position)
        tracerStart = (on and d > 0) and sp or Vector2.new(vp.X * 0.5, vp.Y * 0.5)
    else
        tracerStart = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
    end

    -- ── Shared render function ────────────────────────────────
    local function renderEntry(d, char, hrp, hum, nameStr, infoStr)
        local sp, onScreen, depth = w2s(hrp.Position)
        if not onScreen or depth <= 0 then hideAll(d); return end

        d.hl.Adornee = char; d.hl.Enabled = true

        d.bb.Adornee   = hrp; d.bb.Enabled = true
        d.nameLbl.Text = nameStr
        d.infoLbl.Text = infoStr

        local bx0, by0, bx1, by1 = charBounds(char)
        if bx0 then
            bx0 -= 3; by0 -= 3; bx1 += 3; by1 += 3
            drawLine(d.boxLines[1], Vector2.new(bx0, by0), Vector2.new(bx1, by0), 2)
            drawLine(d.boxLines[2], Vector2.new(bx0, by1), Vector2.new(bx1, by1), 2)
            drawLine(d.boxLines[3], Vector2.new(bx0, by0), Vector2.new(bx0, by1), 2)
            drawLine(d.boxLines[4], Vector2.new(bx1, by0), Vector2.new(bx1, by1), 2)
        else
            for _, l in ipairs(d.boxLines) do l.Visible = false end
        end

        drawLine(d.tracer, tracerStart, sp, 2)

        for i, bone in ipairs(BONES) do
            local pA = char:FindFirstChild(bone[1])
            local pB = char:FindFirstChild(bone[2])
            local ln = d.skelLines[i]
            if pA and pB then
                local sA, onA, dA = w2s(pA.Position)
                local sB, onB, dB = w2s(pB.Position)
                if (onA or onB) and dA > 0 and dB > 0 then
                    drawLine(ln, sA, sB, 1.5)
                else
                    ln.Visible = false
                end
            else
                ln.Visible = false
            end
        end
    end

    -- ── Render players ────────────────────────────────────────
    for p, d in pairs(espCache) do
        local char = p.Character
        if not char then hideAll(d); continue end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp then hideAll(d); continue end
        local hp    = hum and math.floor(hum.Health)    or 0
        local maxHp = hum and math.floor(hum.MaxHealth) or 100
        local dist  = mh and math.floor((hrp.Position - mh.Position).Magnitude) or 0

        -- Line 1: name + username
        local nameStr = string.format("%s  [%s]", p.DisplayName, p.Name)

        -- Line 2: HP | dist | team
        local teamName = p.Team and p.Team.Name or "None"
        local infoStr  = string.format("HP %d/%d  |  %d studs  |  %s", hp, maxHp, dist, teamName)

        -- Line 3: leaderstats (e.g. Money: 500  Kills: 3)
        local ls = p:FindFirstChild("leaderstats")
        if ls then
            local parts = {}
            for _, stat in ipairs(ls:GetChildren()) do
                table.insert(parts, stat.Name .. ": " .. tostring(stat.Value))
            end
            if #parts > 0 then
                infoStr = infoStr .. "\n" .. table.concat(parts, "  |  ")
            end
        end

        renderEntry(d, char, hrp, hum, nameStr, infoStr)
    end

    -- ── Render bots (orange) ──────────────────────────────────
    for model, d in pairs(botCache) do
        if not model or not model.Parent then destroyBotESP(model); continue end
        local hrp = model:FindFirstChild("HumanoidRootPart")
        local hum = model:FindFirstChildOfClass("Humanoid")
        if not hrp then hideAll(d); continue end
        local hp    = hum and math.floor(hum.Health)    or 0
        local maxHp = hum and math.floor(hum.MaxHealth) or 100
        local dist  = mh and math.floor((hrp.Position - mh.Position).Magnitude) or 0
        renderEntry(d, model, hrp, hum,
            string.format("[BOT] %s", model.Name),
            string.format("HP %d/%d  |  %d studs", hp, maxHp, dist))
    end
end)


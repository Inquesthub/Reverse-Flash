-- ── Core fly function (provided implementation) ────────────
local function F(p, s)
    local plr = p or lp
    local spd = s or flySpeed
    local c   = plr.Character or plr.CharacterAdded:Wait()
    local h   = c:WaitForChild("Humanoid")
    local r   = c:WaitForChild("HumanoidRootPart")
    local bv  = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bv.Velocity = Vector3.zero
    bv.P        = 1e5
    bv.Parent   = r
    local con
    con = RunService.RenderStepped:Connect(function()
        if bv and bv.Parent then
            if h.MoveDirection.Magnitude > 0 then
                bv.Velocity = cam.CFrame.LookVector * spd
                r.CFrame    = CFrame.new(r.Position, r.Position + cam.CFrame.LookVector)
            else
                bv.Velocity = Vector3.zero
            end
        else
            if con then con:Disconnect() end
        end
    end)
    return function()
        if con then con:Disconnect() end
        if bv  then bv:Destroy() end
    end
end

local function doEnableFly()
    flyCleanup = F(lp, flySpeed)
end

local function doDisableFly()
    if flyCleanup then flyCleanup(); flyCleanup = nil end
end

newToggle(flySection, "Enable Fly", function(on)
    flyEnabled = on
    if on then doEnableFly() else doDisableFly() end
    Notify("Fly " .. (on and "enabled" or "disabled"))
end)


local BaseViewport = Vector2.new(1539, 804)
local DefaultColor = Color3.fromRGB(249, 210, 49)
local Active       = {}
local Counter      = 0

local function TypeWrite(text, callback, speed)
    local start = tick()
    local len   = utf8.len(text)
    local dur   = len / (speed or 25)
    callback("")
    local conn
    conn = RunService.Heartbeat:Connect(function()
        local p = (tick() - start) / dur
        if p > 1 then conn:Disconnect(); p = 1 end
        callback(string.sub(text, 1, math.floor(p * len)))
    end)
    return conn
end

local function GetLines(text)
    local p = Instance.new("GetTextBoundsParams")
    p.Text  = text
    p.Font  = Font.new("rbxasset://fonts/families/SourceSansPro.json",
                        Enum.FontWeight.Bold, Enum.FontStyle.Italic)
    p.Size  = 24
    p.Width = 312
    return math.ceil(TextService:GetTextBoundsAsync(p).Y / 24)
end

-- NotificationGui must exist in PlayerGui (add it in Studio or via another script)
local Gui       = lp:WaitForChild("PlayerGui"):WaitForChild("NotificationGui")
Gui.DisplayOrder = 9
local Templates = Gui:WaitForChild("Templates")

cam:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    for _, frame in pairs(Active) do
        local vs   = cam.ViewportSize
        local min  = math.min(vs.X, vs.Y)
        local base = math.min(BaseViewport.X, BaseViewport.Y)
        frame.Message.TextSize    = math.floor(24 * (vs.Y / BaseViewport.Y))
        frame.UIStroke.Thickness  = min / base * 3
    end
end)

function Notify(text, duration)
    duration = duration or math.min(5, 4 * utf8.len(text) / 50)
    Counter  = Counter + 1
    local frame = Templates.Notification:Clone()
    frame.Visible      = true
    frame.LayoutOrder  = -Counter
    frame.UIStroke.Color = DefaultColor
    frame.Message.Text = text
    frame.Message.MaxVisibleGraphemes = 0

    local lines = GetLines(text)
    local size  = lines > 1
        and UDim2.fromScale(frame.Size.X.Scale, frame.Size.Y.Scale * (1 + 0.5 * (lines - 1)))
        or  UDim2.fromScale(frame.Size.X.Scale, frame.Size.Y.Scale)

    local vs   = cam.ViewportSize
    local min  = math.min(vs.X, vs.Y)
    local base = math.min(BaseViewport.X, BaseViewport.Y)
    frame.Message.TextSize   = math.floor(24 * (vs.Y / BaseViewport.Y))
    frame.UIStroke.Thickness = min / base * 3
    frame.Size = UDim2.fromScale(frame.Size.X.Scale, 0)

    TweenService:Create(frame, TweenInfo.new(0.2), { Size = size }):Play()

    local click = Instance.new("Sound")
    click.SoundId = "rbxassetid://215658476"
    click.Volume  = 0.3
    click.Parent  = frame

    frame.Parent = Gui.Container
    table.insert(Active, frame)

    local step = 1
    TypeWrite(text, function(t)
        if step == 1 and Gui.Enabled then click:Play() end
        step = step % 3 + 1
        frame.Message.MaxVisibleGraphemes = utf8.len(t)
    end, 50)

    task.delay(duration, function()
        TweenService:Create(frame,          TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
        TweenService:Create(frame.Message,  TweenInfo.new(0.3), { TextTransparency = 1 }):Play()
        TweenService:Create(frame.UIStroke, TweenInfo.new(0.3), { Transparency = 1 }):Play()
        task.delay(0.3, function()
            frame:Destroy()
            local i = table.find(Active, frame)
            if i then table.remove(Active, i) end
        end)
    end)
end

